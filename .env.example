# -----------------------------------------------------------------------------
# BRAUSERIS KASUTATAVAD VÕTMED
# Supabase Dashboard -> Project Settings -> API Keys / Connect
# Need kaks VITE_ väärtust jõuavad rakenduse bundle'isse ja tohivad olla avalikud.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Poe alamdomeenide juurdomeen. Tootmises jäta poeruum.ee; lokaalselt saab
# alamdomeene proovida väärtusega localhost ja aadressiga test.localhost:5173.
VITE_STOREFRONT_ROOT_DOMAIN=poeruum.ee

# -----------------------------------------------------------------------------
# SUPABASE'I HALDUS (AINULT LOKAALNE; ÄRA LISA VITE_ PREFIKSIT)
# -----------------------------------------------------------------------------

# Account -> Access Tokens -> Generate new token
# Vajalik CLI kaudu projekti linkimiseks ja haldamiseks.
SUPABASE_ACCESS_TOKEN=

# Projekti Reference ID: Project Settings -> General
# Näide: abcdefghijklmnopqrst
SUPABASE_PROJECT_REF=

# Projekti Postgres-parool, mille määrasid projekti loomisel.
# Vajalik migratsioonide rakendamiseks käsuga `npm run supabase:deploy`.
SUPABASE_DB_PASSWORD=

# Project Settings -> API Keys -> Secret keys (sb_secret_...)
# Annab serveripoolse täisligipääsu andmetele ja möödub RLS-ist.
# Ära kasuta seda kunagi src/ koodis ega brauseris.
SUPABASE_SECRET_KEY=

# Ainult siis, kui projekt kasutab veel legacy võtmeid ja Secret key puudub.
# Project Settings -> API Keys -> Legacy API Keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# STRIPE (ALUSTA SANDBOXI / TEST MODE VÕTMETEGA)
# Stripe Dashboard -> Developers -> API keys
# -----------------------------------------------------------------------------

# Avalik brauserivõti (pk_test_... või tootmises pk_live_...).
# Ainult see Stripe'i võti võib olla VITE_ prefiksiga ja jõuda frontend bundle'isse.
VITE_STRIPE_PUBLISHABLE_KEY=

# Serverivõti (testis sk_test_... või sobivate õigustega rk_test_...).
# Ära lisa VITE_ prefiksit ega kasuta seda src/ koodis.
STRIPE_SECRET_KEY=

# Kaitse test- ja live-andmete segamise vastu. Lubatud väärtused: test või live.
STRIPE_MODE=test

# Stripe Dashboard -> Developers -> Webhooks -> Poeruumi endpoint -> Signing secret
# Test- ja live-endpointidel on erinev whsec_... väärtus.
STRIPE_WEBHOOK_SECRET=

# Connect -> Webhooks -> "Events on connected accounts" endpoint -> Signing secret
# Hoia eraldi, sest iga webhook endpoint saab Stripe'ilt oma whsec_... väärtuse.
STRIPE_CONNECT_WEBHOOK_SECRET=

# Stripe Billingu 29 € kuupaketi korduv Price ID (price_...).
# See ei ole võti, kuid Checkout Sessioni loomisel on seda vaja.
STRIPE_FIXED_PLAN_PRICE_ID=

# Stripe Tax Rates alt loodud Eesti 24% käibemaksumäära ID (txr_...).
# Nõutav nii testis kui tootmises, et Checkout vastaks kuvatavale hinnale.
# Kui väärtus on olemas, lisab Checkout maksu 29 € netohinnale.
STRIPE_FIXED_PLAN_TAX_RATE_ID=

# Rakenduse avalik HTTPS-aadress Stripe Checkouti ning Connect onboarding'u
# return_url, refresh_url, success_url ja cancel_url koostamiseks.
APP_URL=http://localhost:5173

# Kasutatakse Stripe'i tagasisuunamisel poe alamdomeeni usaldamiseks.
# Tootmises peab kattuma VITE_STOREFRONT_ROOT_DOMAIN väärtusega.
STOREFRONT_ROOT_DOMAIN=poeruum.ee

# -----------------------------------------------------------------------------
# RENDER CUSTOM DOMAINS (AINULT SUPABASE EDGE FUNCTIONITES)
# -----------------------------------------------------------------------------

# Render Account Settings -> API Keys. Võti peab jääma ainult serverisse.
RENDER_API_KEY=

# Renderi web service'i ID kujul srv-...
RENDER_SERVICE_ID=

# Sama teenuse onrender.com hostinimi ilma https:// prefiksita.
# Seda näidatakse alamdomeeni ühendamisel CNAME-kirje väärtusena.
RENDER_SERVICE_HOSTNAME=poeruum.onrender.com

# Renderi avalik load balancer IP juurdomeenide A-kirjeks.
RENDER_APEX_IPV4=216.24.57.1

# Ainult siis, kui otsustame hiljem olemasolevaid Standard-kontosid ühendada
# legacy OAuth flow kaudu. Stripe-hosted Account Links seda ei vaja.
# Serveripoolne e-posti saatmine (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Poeruum <teavitused@send.poeruum.ee>
# Genereeritakse production'is cron-töö autentimiseks; ära kasuta brauseris.
ONBOARDING_CRON_SECRET=
